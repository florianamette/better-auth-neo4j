# Copy to .env.local and adjust. Used by Next.js and db:schema.

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=examplepassword
# Optional Neo4j database name (default database if unset)
# NEO4J_DATABASE=neo4j

BETTER_AUTH_SECRET=replace-with-a-long-random-string-at-least-32-chars
# Must match the URL you open in the browser (including port if not 3000).
BETTER_AUTH_URL=http://localhost:3111
# Optional: the example client uses window.location.origin in the browser. Set this only if you need a fixed public URL (e.g. some SSR setups).
# NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
