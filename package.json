{
  "name": "neo4j-better-auth",
  "version": "0.1.0",
  "description": "Better Auth database adapter for Neo4j (nodes + relationship edges for foreign keys)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish --provenance",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "better-auth",
    "neo4j",
    "cypher",
    "authentication",
    "adapter"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/florianamette/better-auth-neo4j.git"
  },
  "bugs": {
    "url": "https://github.com/florianamette/better-auth-neo4j/issues"
  },
  "homepage": "https://github.com/florianamette/better-auth-neo4j#readme",
  "peerDependencies": {
    "@neo4j/cypher-builder": "^3.0.1",
    "better-auth": "^1.5.0",
    "neo4j-driver": "^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "@better-auth/test-utils": "^1.5.6",
    "@changesets/cli": "^2.30.0",
    "@neo4j/cypher-builder": "^3.0.1",
    "@testcontainers/neo4j": "^11.0.0",
    "@types/node": "^25.5.0",
    "better-auth": "^1.5.6",
    "neo4j-driver": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9"
}
